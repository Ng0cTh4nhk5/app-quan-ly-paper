  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function fmt(days) {",
          "  const d = new Date();",
          "  d.setDate(d.getDate() + days);",
          "  return d.toISOString().slice(0, 10);",
          "}",
          "pm.environment.set('deadlineBoSung', fmt(14));",
          "pm.environment.set('deadlinePb', fmt(30));",
          "pm.environment.set('ngayKy', fmt(1));"
        ]
      }
    }
  ],
